# ===========================================
# PhishLens Backend Environment Configuration
# ===========================================

# Database
DATABASE_URL=postgresql://phishlens_user:your_password_here@localhost:5432/phishlens_db

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# CORS
FRONTEND_URL=http://localhost:3000

# Application
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_RESEARCHER=30
RATE_LIMIT_ADMIN=100

# Security
API_KEY_ENCRYPTION_KEY=your-aes-256-encryption-key-here

# Ethical Safeguards
TERMS_VALIDITY_DAYS=90
ABUSE_DETECTION_STD_DEVS=2.0
